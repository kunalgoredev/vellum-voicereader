{
  "name": "vellum",
  "version": "1.0.0",
  "description": "Local AI Voice Studio — runs entirely on your machine",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --arm64 --x64"
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.vellum.voicestudio",
    "productName": "Vellum",
    "copyright": "Vellum Voice Studio",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!**/__pycache__/**",
      "!**/*.pyc",
      "!**/*.pyo",
      "!.venv/**/*",
      "!models/**/*",
      "!outputs/**/*",
      "!dist/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "app",
        "to": "app"
      },
      {
        "from": "web",
        "to": "web"
      },
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "requirements-lock.txt",
        "to": "requirements-lock.txt"
      },
      {
        "from": "resources/tools",
        "to": "tools"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": false,
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": ["**/*", "!get-pip.py"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        {
          "from": "resources/python",
          "to": "python",
          "filter": ["**/*", "!get-pip.py"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "resources/icon.ico"
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
